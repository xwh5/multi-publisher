{
  "name": "multi-publisher",
  "version": "1.0.3",
  "description": "Markdown → 微信公众号 / 知乎 / 掘金等多平台 CLI 发布工具",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/xwh5/multi-publisher"
  },
  "bin": {
    "mpub": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "preview": "npx serve themes"
  },
  "keywords": [
    "markdown",
    "publish",
    "wechat",
    "zhihu",
    "juejin",
    "csdn",
    "cli",
    "multi-platform",
    "content-publishing"
  ],
  "author": "",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "themes"
  ],
  "dependencies": {
    "@inquirer/input": "^5.0.0",
    "@inquirer/password": "^5.0.0",
    "axios": "^1.15.0",
    "commander": "^14.0.0",
    "form-data": "^4.0.5",
    "form-data-encoder": "^4.0.0",
    "formdata-node": "^6.0.0",
    "front-matter": "^4.0.0",
    "highlight.js": "^11.10.0",
    "js-md5": "^0.8.3",
    "jsdom": "^27.0.0",
    "juice": "^10.0.0",
    "marked": "^15.0.0",
    "marked-highlight": "^2.2.0",
    "mathjax-full": "^3.2.0",
    "playwright": "^1.59.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/form-data": "^2.2.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
